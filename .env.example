# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/mailingperson?retryWrites=true&w=majority"

# NextAuth v5
AUTH_SECRET="generate-a-strong-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_ID=""
GOOGLE_SECRET=""

# Encryption key for securing app passwords (generate a strong 32+ character key)
ENCRYPTION_KEY="generate-a-strong-encryption-key-here-minimum-32-characters"

# Note: SMTP credentials are now configured per-user in the Settings page
# using Gmail App Passwords. No need for SMTP environment variables.

# Upstash Redis (optional - for queue system)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
